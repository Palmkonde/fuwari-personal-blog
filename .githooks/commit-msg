#!/bin/sh
# Enforce Conventional Commits (see CONTRIBUTING.md)
subject=$(head -1 "$1")
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9.-]+\))?!?: .+'

if ! echo "$subject" | grep -qE "$pattern"; then
  echo "Commit subject must match Conventional Commits: <type>(scope): subject" >&2
  echo "following type: (feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)"
  echo "  e.g. fix(navbar): correct client:only prop typing" >&2
  echo "Got: $subject" >&2
  exit 1
fi

if [ "${#subject}" -gt 72 ]; then
  echo "Commit subject too long (${#subject} > 72 chars): $subject" >&2
  exit 1
fi
